{
  "name": "liteurl",
  "private": true,
  "version": "1.0.0",
  "description": "Self-hosted URL shortener with analytics",
  "packageManager": "pnpm@10.28.2",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "types:check": "pnpm -r types:check"
  }
}
