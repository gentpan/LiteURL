{
  "name": "api",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/app.ts",
  "scripts": {
    "dev": "node --env-file=.env --import=tsx/esm src/app.ts",
    "build": "node --import=tsx/esm node_modules/.bin/tsc --noEmit",
    "start": "node --env-file=.env dist/app.js",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "models": "workspace:*",
    "hono": "^4.12.29",
    "@hono/node-server": "^2.0.8",
    "better-sqlite3": "^11.8.1",
    "zod": "^3.24.4",
    "nanoid": "^5.1.5",
    "ua-parser-js": "^2.0.10",
    "intl-parse-accept-language": "^1.0.0",
    "ofetch": "^1.4.1",
    "destr": "^2.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ua-parser-js": "^0.7.39",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}
